{
  "kind": "Dashboard",
  "metadata": {
    "name": "repoguard-status-ops",
    "createdAt": "2026-04-24T21:55:54.323800969Z",
    "updatedAt": "2026-04-24T21:55:54.323800969Z",
    "version": 0,
    "project": "greenhouse"
  },
  "spec": {
    "display": {
      "name": "Repo Guard • Status & Operations"
    },
    "panels": {
      "apiAuthErrors": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "🔑 API Auth Errors (401)"
          },
          "plugin": {
            "kind": "StatChart",
            "spec": {
              "calculation": "last-number",
              "thresholds": {
                "steps": [
                  {
                    "color": "green",
                    "value": 0
                  },
                  {
                    "color": "red",
                    "value": 1
                  }
                ]
              }
            }
          },
          "queries": [
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "query": "sum(increase(repo_guard_external_api_requests_total{status=\"401\"}[1h])) or vector(0)"
                  }
                }
              }
            }
          ]
        }
      },
      "apiErrorRates": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "📡 API Error Rates (Non-2xx)"
          },
          "plugin": {
            "kind": "TimeSeriesChart",
            "spec": {
              "legend": {
                "position": "bottom"
              }
            }
          },
          "queries": [
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "query": "sum by (status) (increase(repo_guard_external_api_requests_total{status!~\"2..|3..\"}[5m]))",
                    "seriesNameFormat": "HTTP {{status}}"
                  }
                }
              }
            }
          ]
        }
      },
      "orgFailures": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "🚫 Org Failures"
          },
          "plugin": {
            "kind": "StatChart",
            "spec": {
              "calculation": "last-number",
              "thresholds": {
                "steps": [
                  {
                    "color": "green",
                    "value": 0
                  },
                  {
                    "color": "red",
                    "value": 1
                  }
                ]
              }
            }
          },
          "queries": [
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "query": "sum(repo_guard_githuborganization_status{status=\"failed\", github=~\"$github\", organization=~\"$org\"} == 1) or vector(0)"
                  }
                }
              }
            }
          ]
        }
      },
      "orgPending": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "⏳ Org Pending Ops"
          },
          "plugin": {
            "kind": "StatChart",
            "spec": {
              "calculation": "last-number",
              "thresholds": {
                "steps": [
                  {
                    "color": "green",
                    "value": 0
                  },
                  {
                    "color": "orange",
                    "value": 1
                  }
                ]
              }
            }
          },
          "queries": [
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "query": "sum(repo_guard_githuborganization_operations{state=\"pending\", github=~\"$github\", organization=~\"$org\"}) or vector(0)"
                  }
                }
              }
            }
          ]
        }
      },
      "orgsAttention": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "🏢 Organizations Needing Attention"
          },
          "plugin": {
            "kind": "Table",
            "spec": {
              "columnSettings": [
                {
                  "name": "value",
                  "hide": true
                },
                {
                  "name": "Value",
                  "hide": true
                },
                {
                  "name": "timestamp",
                  "hide": true
                },
                {
                  "name": "Time",
                  "hide": true
                }
              ]
            }
          },
          "queries": [
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "query": "sum by (github, organization, status) (repo_guard_githuborganization_status{github=~\"$github\", organization=~\"$org\", status=~\"failed|ratelimited|pending\"} == 1)"
                  }
                }
              }
            }
          ]
        }
      },
      "peopleOps": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "👤 People Operations"
          },
          "plugin": {
            "kind": "TimeSeriesChart",
            "spec": {
              "legend": {
                "position": "bottom"
              }
            }
          },
          "queries": [
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "query": "sum by (operation) (repo_guard_githubteam_operations{state=\"complete\", organization=~\"$org\", team=~\"$team\"}) + sum by (operation) (repo_guard_githuborganization_operations{scope=\"owners\", state=\"complete\", github=~\"$github\", organization=~\"$org\"})",
                    "seriesNameFormat": "Member {{operation}}"
                  }
                }
              }
            }
          ]
        }
      },
      "rateLimitStatus": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "🚦 Rate Limit Status"
          },
          "plugin": {
            "kind": "StatChart",
            "spec": {
              "calculation": "last-number",
              "thresholds": {
                "steps": [
                  {
                    "color": "green",
                    "value": 0
                  },
                  {
                    "color": "orange",
                    "value": 1
                  }
                ]
              }
            }
          },
          "queries": [
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "query": "sum(repo_guard_githuborganization_status{status=\"ratelimited\", github=~\"$github\", organization=~\"$org\"} == 1) or vector(0)"
                  }
                }
              }
            }
          ]
        }
      },
      "reconcileDuration": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "⏱️ Reconcile Duration (p95)"
          },
          "plugin": {
            "kind": "TimeSeriesChart",
            "spec": {
              "legend": {
                "position": "bottom"
              }
            }
          },
          "queries": [
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "query": "histogram_quantile(0.95, sum by (le, controller) (rate(repo_guard_controller_reconcile_duration_seconds_bucket[5m])))",
                    "seriesNameFormat": "{{controller}} p95"
                  }
                }
              }
            }
          ]
        }
      },
      "teamFailures": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "🚫 Team Failures"
          },
          "plugin": {
            "kind": "StatChart",
            "spec": {
              "calculation": "last-number",
              "thresholds": {
