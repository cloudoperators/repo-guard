            }
          },
          "queries": [
            {
              "kind": "TimeSeriesQuery",
              "spec": {
                "plugin": {
                  "kind": "PrometheusTimeSeriesQuery",
                  "spec": {
                    "query": "sum(repo_guard_githubteam_status{status=\"failed\", organization=~\"$org\", team=~\"$team\"} == 1) or vector(0)"
                  }
                }
              }
            }
          ]
        }
      },
      "teamPending": {
        "kind": "Panel",
