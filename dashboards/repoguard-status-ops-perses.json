      }
    ],
    "variables": [
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "GitHub",
            "hidden": false
          },
          "allowAllValue": true,
          "allowMultiple": true,
          "plugin": {
            "kind": "PrometheusLabelValuesVariable",
            "spec": {
              "labelName": "github",
              "matchers": [
                "repo_guard_githuborganization_status"
              ]
            }
          },
          "name": "github",
          "defaultValue": "$__all"
        }
      },
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "Organization",
            "hidden": false
          },
          "allowAllValue": true,
          "allowMultiple": true,
          "plugin": {
            "kind": "PrometheusLabelValuesVariable",
            "spec": {
              "labelName": "organization",
              "matchers": [
                "repo_guard_githuborganization_status"
              ]
            }
          },
          "name": "org",
          "defaultValue": "$__all"
        }
      },
      {
        "kind": "ListVariable",
        "spec": {
          "display": {
            "name": "Team",
            "hidden": false
          },
          "allowAllValue": true,
          "allowMultiple": true,
          "plugin": {
            "kind": "PrometheusLabelValuesVariable",
            "spec": {
              "labelName": "team",
              "matchers": [
                "repo_guard_githubteam_status"
              ]
            }
          },
          "name": "team",
          "defaultValue": "$__all"
        }
      }
    ],
    "duration": "1d",
